{
  "plugins": ["react", "import"],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "src/apps/web/frontend/**",
              "src/apps/web/frontend/src/lib/components/**",
              "src/apps/web/frontend/src/lib/components/graph/edges/**",
              "src/apps/web/frontend/src/lib/components/graph/nodes/**",
              "src/apps/web/frontend/src/lib/components/icons/**",
              "src/apps/web/frontend/src/lib/constants/**",
              "src/apps/web/frontend/src/lib/sections/audio/**",
              "src/apps/web/frontend/src/lib/sections/chat/**",
              "src/apps/web/frontend/src/lib/sections/effects/**",
              "src/apps/web/frontend/src/lib/sections/home/**",
              "src/apps/web/frontend/src/lib/sections/layout/**",
              "src/apps/web/frontend/src/lib/sections/theme/**",
              "src/apps/web/frontend/src/lib/sections/workflows/**",
              "src/apps/web/frontend/src/lib/sections/workflows/ExecutionHistory/**",
              "src/apps/web/frontend/src/lib/sections/workflows/WorkflowBuilder/CanvasControls/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Material Symbols Outlined))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Material Symbols Outlined."
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/index.js"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
