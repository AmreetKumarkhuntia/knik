# Knik Configuration Template
# Copy this file to .env and customize your settings

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
export KNIK_SHOW_LOGS=true
export KNIK_LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
export KNIK_USE_COLORS=true      # Set to false if your terminal doesn't support ANSI colors

# ─────────────────────────────────────────────
# Python / Build
# ─────────────────────────────────────────────
# Force native ARM64 execution (no Rosetta) — macOS only
export ARCHFLAGS="-arch arm64"

# ─────────────────────────────────────────────
# TTS (Text-to-Speech)
# ─────────────────────────────────────────────
export KNIK_VOICE_OUTPUT=true
export KNIK_VOICE=af_sarah        # af_heart | af_bella | af_sarah | af_nicole | af_sky | am_adam | am_michael | am_leo | am_ryan
export KNIK_LANGUAGE=a            # a=american_english | b=british_english | es | fr | it | pt | de | ja | zh | ko
export KNIK_MODEL=hexgrad/Kokoro-82M

# ─────────────────────────────────────────────
# AI — General
# ─────────────────────────────────────────────
export KNIK_AI_PROVIDER=vertex    # vertex | gemini | glm | mock
export KNIK_AI_MODEL=gemini-2.5-flash
export KNIK_MAX_TOKENS=25565
export KNIK_TEMPERATURE=0.7
# export KNIK_AI_SYSTEM_INSTRUCTION="You are a helpful AI assistant with voice capabilities. Be concise and conversational."

# ─────────────────────────────────────────────
# AI — Vertex AI (Google Cloud)
# Set KNIK_AI_PROVIDER=vertex to use this
# ─────────────────────────────────────────────
export KNIK_AI_LOCATION=us-central1
export GOOGLE_CLOUD_PROJECT=your-project-id-here

# ─────────────────────────────────────────────
# AI — Gemini AI Studio
# Set KNIK_AI_PROVIDER=gemini to use this
# ─────────────────────────────────────────────
# export GEMINI_API_KEY=your-gemini-api-key-here

# ─────────────────────────────────────────────
# AI — ZhipuAI (GLM)
# Set KNIK_AI_PROVIDER=glm to use this
# Models: glm-4 | glm-4-flash | glm-4-air | glm-4v | glm-4.5-flash
# Get a key at: https://bigmodel.cn
# ─────────────────────────────────────────────
# export KNIK_AI_MODEL=glm-4.5-flash
# export ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# ─────────────────────────────────────────────
# AI — Z.AI (Z.AI Platform)
# Set KNIK_AI_PROVIDER=zai to use this
# Models: glm-5 | glm-4 | glm-4-flash
# Get a key at: https://z.ai/model-api
# ─────────────────────────────────────────────
# export KNIK_AI_PROVIDER=zai
# export KNIK_AI_MODEL=glm-5
# export ZAI_API_KEY=your-zai-api-key-here
# export ZAI_API_BASE=https://api.z.ai/api/paas/v4/

# ─────────────────────────────────────────────
# Web Backend
# ─────────────────────────────────────────────
export KNIK_WEB_HOST=0.0.0.0
export KNIK_WEB_PORT=8000
export KNIK_WEB_RELOAD=true

# ─────────────────────────────────────────────
# History / Context
# ─────────────────────────────────────────────
export KNIK_HISTORY_CONTEXT_SIZE=5    # messages sent as context to the AI
export KNIK_MAX_HISTORY_SIZE=50       # max messages stored in GUI history

# ─────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────
export KNIK_DB_HOST=localhost
export KNIK_DB_PORT=5432
export KNIK_DB_USER=user
export KNIK_DB_PASS=password
export KNIK_DB_NAME=knik
export KNIK_SCHEDULER_CHECK_INTERVAL=60   # seconds between job checks
export KNIK_SCHEDULER_WORKERS=4
export KNIK_SCHEDULER_MAX_CONCURRENT=10
